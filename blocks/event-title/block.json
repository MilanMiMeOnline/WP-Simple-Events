{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wpse/event-title",
  "title": "Event Title",
  "category": "wp-simple-events",
  "icon": "heading",
  "description": "Display the title of the current or selected event.",
  "textdomain": "wp-simple-events",
  "usesContext": ["postId", "postType"],
  "attributes": {
    "eventId": { "type": "integer", "default": 0 },
    "heading": { "type": "string", "default": "h2" },
    "link": { "type": "boolean", "default": false }
  },
  "supports": {
    "html": false,
    "anchor": true,
    "align": ["wide", "full"],
    "color": { "text": true, "link": true },
    "spacing": { "margin": true },
    "typography": { "fontSize": true, "lineHeight": true }
  },
  "editorScript": "wpse-event-fields-editor",
  "style": "wpse-frontend"
}
