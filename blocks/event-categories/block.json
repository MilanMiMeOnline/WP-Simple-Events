{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wpse/event-categories",
  "title": "Event Categories",
  "category": "simple-events-by-mime",
  "icon": "category",
  "description": "Display linked categories for the current or selected event.",
  "textdomain": "simple-events-by-mime",
  "usesContext": ["postId", "postType"],
  "attributes": {
    "eventId": { "type": "integer", "default": 0 },
    "showLabel": { "type": "boolean", "default": true },
    "label": { "type": "string", "default": "" }
  },
  "supports": {
    "html": false,
    "anchor": true,
    "align": ["wide", "full"],
    "color": { "text": true, "link": true },
    "spacing": { "margin": true },
    "typography": { "fontSize": true, "lineHeight": true }
  },
  "editorScript": "wpse-event-fields-editor",
  "style": "wpse-frontend"
}
