{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wpse/event-excerpt",
  "title": "Event Excerpt",
  "category": "wp-simple-events",
  "icon": "excerpt-view",
  "description": "Display the excerpt of the current or selected event.",
  "textdomain": "wp-simple-events",
  "usesContext": ["postId", "postType"],
  "attributes": { "eventId": { "type": "integer", "default": 0 } },
  "supports": {
    "html": false,
    "anchor": true,
    "align": ["wide", "full"],
    "color": { "text": true, "link": true },
    "spacing": { "margin": true },
    "typography": { "fontSize": true, "lineHeight": true }
  },
  "editorScript": "wpse-event-fields-editor",
  "style": "wpse-frontend"
}
