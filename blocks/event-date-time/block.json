{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wpse/event-date-time",
  "title": "Event Date & Time",
  "category": "wp-simple-events",
  "icon": "calendar-alt",
  "description": "Display the localized date, time and optional timezone of an event.",
  "textdomain": "wp-simple-events",
  "usesContext": ["postId", "postType"],
  "attributes": {
    "eventId": { "type": "integer", "default": 0 },
    "showLabel": { "type": "boolean", "default": true },
    "label": { "type": "string", "default": "" }
  },
  "supports": {
    "html": false,
    "anchor": true,
    "align": ["wide", "full"],
    "color": { "text": true, "link": true },
    "spacing": { "margin": true },
    "typography": { "fontSize": true, "lineHeight": true }
  },
  "editorScript": "wpse-event-fields-editor",
  "style": "wpse-frontend"
}
